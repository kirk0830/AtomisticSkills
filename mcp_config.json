{
  "mcpServers": {
    "base": {
      "command": "PIXI_PROJECT/.pixi/envs/base/bin/python",
      "args": [
        "-m",
        "src.mcp_server.base_server"
      ],
      "env": {
        "PYTHONPATH": "PIXI_PROJECT"
      }
    },
    "mace": {
      "command": "PIXI_PROJECT/.pixi/envs/mace/bin/python",
      "args": [
        "-m",
        "src.mcp_server.mace_server"
      ],
      "env": {
        "PYTHONPATH": "PIXI_PROJECT",
        "CONDA_PREFIX": "PIXI_PROJECT/.pixi/envs/mace",
        "TRITON_PTXAS_BLACKWELL_PATH": "PIXI_PROJECT/.pixi/envs/mace/bin/ptxas",
        "PATH": "PIXI_PROJECT/.pixi/envs/mace/bin:/usr/local/cuda/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
        "CONDA_OVERRIDE_CUDA": "12",
        "CUDA_LAUNCH_BLOCKING": "1",
        "TORCH_USE_CUDA_DSA": "1"
      }
    },
    "matgl": {
      "command": "PIXI_PROJECT/.pixi/envs/matgl/bin/python",
      "args": [
        "-m",
        "src.mcp_server.matgl_server"
      ],
      "env": {
        "PYTHONPATH": "PIXI_PROJECT",
        "MATGL_BACKEND": "DGL",
        "CONDA_OVERRIDE_CUDA": "12"
      }
    },
    "fairchem": {
      "command": "PIXI_PROJECT/.pixi/envs/fairchem/bin/python",
      "args": [
        "-m",
        "src.mcp_server.fairchem_server"
      ],
      "env": {
        "PYTHONPATH": "PIXI_PROJECT",
        "CONDA_OVERRIDE_CUDA": "12"
      }
    },
    "smol": {
      "command": "PIXI_PROJECT/.pixi/envs/smol/bin/python",
      "args": [
        "-m",
        "src.mcp_server.smol_server"
      ],
      "env": {
        "PYTHONPATH": "PIXI_PROJECT"
      }
    },
    "drugdisc": {
      "command": "PIXI_PROJECT/.pixi/envs/drugdisc/bin/python",
      "args": [
        "-m",
        "src.mcp_server.drugdisc_server"
      ],
      "env": {
        "PYTHONPATH": "PIXI_PROJECT"
      }
    },
    "adit": {
      "command": "PIXI_PROJECT/.pixi/envs/adit/bin/python",
      "args": [
        "-m",
        "src.mcp_server.adit_server"
      ],
      "env": {
        "PYTHONPATH": "PIXI_PROJECT"
      }
    },
    "diffcsp": {
      "command": "PIXI_PROJECT/.pixi/envs/diffcsp/bin/python",
      "args": [
        "-m",
        "src.mcp_server.diffcsp_server"
      ],
      "env": {
        "PYTHONPATH": "PIXI_PROJECT"
      }
    },
    "mattergen": {
      "command": "PIXI_PROJECT/.pixi/envs/mattergen/bin/python",
      "args": [
        "-m",
        "src.mcp_server.mattergen_server"
      ],
      "env": {
        "PYTHONPATH": "PIXI_PROJECT",
        "CONDA_OVERRIDE_CUDA": "11.8"
      }
    },
    "pixi": {
      "command": "PIXI_PROJECT/.pixi/envs/base/bin/python",
      "args": [
        "-m",
        "src.mcp_server.pixi_server"
      ],
      "env": {
        "PYTHONPATH": "PIXI_PROJECT"
      }
    }
  }
}
